# Copie este arquivo para .env e preencha com os valores reais
# O arquivo .env NUNCA deve ser commitado no git

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Banco de Dados Corporativo (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nome_do_banco
DB_USER=usuario
DB_PASSWORD=senha

# --- URL da API FastAPI ---
# Mude se rodar o backend em outro host ou porta
API_BASE=http://127.0.0.1:8000
