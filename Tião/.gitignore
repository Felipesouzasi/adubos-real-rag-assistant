# Ambiente virtual
.venv/
venv/
ENV/
env/

# Variáveis de ambiente (contém credenciais e chaves de API)
.env

# Cache Python
__pycache__/
*.py[cod]
*$py.class

# Bancos SQLite gerados em runtime
*.db
*.sqlite3

# Índice vetorial gerado por update_db.py (binário grande, regenerável com update_db.py)
text_index/
text_json_index/

# PDFs originais (binários grandes — usar update_db.py para regenerar os JSONs)
*.pdf

# IDEs e metadados de SO
.vscode/
.idea/
Thumbs.db
Desktop.ini
.DS_Store
